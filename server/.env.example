# ============================================
# Eclatrecon AI Mail — Environment Configuration
# ============================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# ⚠️ NEVER commit .env to version control

# ──────────────── Server ────────────────
PORT=3001
NODE_ENV=production

# ──────────────── Authentication ────────
# Generate a strong random secret: openssl rand -hex 32
JWT_SECRET=CHANGE_ME_TO_A_RANDOM_64_CHAR_STRING
JWT_EXPIRES_IN=7d

# ──────────────── PostgreSQL ────────────
PG_HOST=127.0.0.1
PG_PORT=5432
PG_DATABASE=eclatrecon_mail
PG_USER=eclatrecon_mail
PG_PASSWORD=your_database_password

# ──────────────── Platform SMTP ─────────
# These credentials are used for system emails
# (password resets, welcome emails, admin notifications)
PLATFORM_SMTP_HOST=smtp.yourdomain.com
PLATFORM_SMTP_PORT=465
PLATFORM_SMTP_USER=noreply@yourdomain.com
PLATFORM_SMTP_PASS=your_smtp_password
PLATFORM_SMTP_FROM="Your App Name <noreply@yourdomain.com>"

# ──────────────── Domain ────────────────
APP_DOMAIN=http://localhost:3001
FRONTEND_URL=http://localhost:3001

# ──────────────── File Upload ───────────
UPLOAD_DIR=./uploads
MAX_ATTACHMENT_SIZE=25000000

# ──────────────── AI (Optional) ─────────
# Get your key at https://openrouter.ai
OPENROUTER_API_KEY=
OPENROUTER_DEFAULT_MODEL=meta-llama/llama-3.1-8b-instruct:free
